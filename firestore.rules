rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions for authentication and authorization
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // Admins are identified via a custom claim on the Auth token.
      // Backend code must set request.auth.token.role = "Admin" for admin users.
      return isAuthenticated() && request.auth.token.role == "Admin";
    }
    
    // Users collection - users can only access their own documents
    match /users/{userId} {
      // Allow read only if authenticated and accessing own document
      allow read: if isAuthenticated() && request.auth.uid == userId;
      
      // Allow update only if authenticated, updating own document,
      // and not changing the authorization-related "role" field
      allow update: if isAuthenticated()
                    && request.auth.uid == userId
                    && request.resource.data.role == resource.data.role;
      
      // Deny create and delete - handled by backend Admin SDK
      allow create, delete: if false;
    }
    
    // Categories collection - public read for authenticated users, admin-only write
    match /categories/{categoryId} {
      // Allow read if authenticated (public data for authenticated users)
      allow read: if isAuthenticated();
      
      // Allow create, update, delete only if admin
      allow create, update, delete: if isAdmin();
    }
    
    // Tips collection - public read for authenticated users, admin-only write
    match /tips/{tipId} {
      // Allow read if authenticated (public data for authenticated users)
      allow read: if isAuthenticated();
      
      // Allow create, update, delete only if admin
      allow create, update, delete: if isAdmin();
    }
    
    // Favorites collection - owner-only access using composite key format {userId}_{tipId}
    match /favorites/{favoriteId} {
      // Allow read only if authenticated and favoriteId starts with user's uid
      allow read: if isAuthenticated() && favoriteId.matches(request.auth.uid + '_.*');
      
      // Allow create only if authenticated, userId in data matches authenticated user,
      // and favoriteId starts with the user's uid to prevent cross-user ID spoofing
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid
                    && favoriteId.matches(request.auth.uid + '_.*');
      
      // Allow delete only if authenticated and favoriteId starts with user's uid
      allow delete: if isAuthenticated() && favoriteId.matches(request.auth.uid + '_.*');
      
      // Deny update - favorites are immutable (delete and recreate instead)
      allow update: if false;
    }
  }
}